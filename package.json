{
  "name": "agentwork",
  "version": "1.0.0",
  "description": "AgentWork - Autonomous AI Agent Orchestrator. Hire, manage, and collaborate with multiple AI agents through a real-time dashboard.",
  "keywords": [
    "ai",
    "agent",
    "orchestrator",
    "claude",
    "gpt",
    "autonomous",
    "kanban",
    "dashboard"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/agentwork.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "bin": {
    "agentwork": "./bin/cli.js"
  },
  "files": [
    "bin/",
    "server/",
    "src/",
    "public/",
    "next.config.mjs",
    "tailwind.config.js",
    "postcss.config.js",
    "jsconfig.json",
    "nodemon.json",
    "package.json",
    "README.md"
  ],
  "scripts": {
    "dev": "nodemon --watch server --ext js,json server/index.js",
    "dev:no-reload": "node server/index.js",
    "build": "next build",
    "start": "NODE_ENV=production node server/index.js",
    "setup": "npm install && npm run build && echo '\\n✓ AgentWork ready! Run: npm start'",
    "postinstall": "[ \"$npm_config_global\" = 'true' ] && npm run build || true",
    "lint": "next lint"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.74",
    "@anthropic-ai/sdk": "^0.39.0",
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@openai/codex-sdk": "^0.114.0",
    "@slack/bolt": "^4.6.0",
    "@slack/web-api": "^7.15.0",
    "better-sqlite3": "^11.7.0",
    "chalk": "^4.1.2",
    "commander": "^12.1.0",
    "date-fns": "^4.1.0",
    "express": "^4.21.0",
    "framer-motion": "^11.11.0",
    "lucide-react": "^0.460.0",
    "next": "^14.2.0",
    "node-cron": "^4.2.1",
    "openai": "^4.73.0",
    "pm2": "^5.4.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-hot-toast": "^2.4.1",
    "socket.io": "^4.8.0",
    "socket.io-client": "^4.8.0",
    "telegraf": "^4.16.3",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "nodemon": "^3.1.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14"
  }
}
